<?xml version='1.0' encoding='utf-8'?>
<widget id="com.travelmate.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>TravelMate</name>
    <description>Smart Trip Planner &amp; Travel Companion</description>
    <author email="student@stiwk2114.edu" href="https://example.edu">STIWK2114 Student</author>

    <content src="index.html" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <access origin="*" />
    <allow-navigation href="https://*" />
    <allow-navigation href="http://*" />

    <preference name="ScrollEnabled" value="true" />
    <preference name="BackupWebStorage" value="local" />
    <preference name="AndroidLaunchMode" value="singleTask" />
    <preference name="DisallowOverscroll" value="true" />
    <preference name="StatusBarBackgroundColor" value="#0a5e4e" />
    <preference name="Fullscreen" value="false" />
    <preference name="Orientation" value="portrait" />

    <platform name="android">
        <preference name="android-minSdkVersion" value="22" />
        <preference name="android-targetSdkVersion" value="33" />
        <allow-intent href="market:*" />
    </platform>

    <plugin name="cordova-plugin-geolocation" spec="4.1.0" />
    <plugin name="cordova-plugin-camera" spec="7.0.0" />
    <plugin name="cordova-plugin-device" spec="3.0.0" />
</widget>
